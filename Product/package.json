{
  "name": "product-tower-kit",
  "version": "1.4.0",
  "description": "Product management toolkit for vibe coders — validate ideas before you code. For Claude Code, Cursor, and AI coding tools.",
  "main": "index.js",
  "bin": {
    "product-tower": "./bin/product-tower.js"
  },
  "scripts": {
    "test": "echo \"No tests yet\"",
    "lint": "echo \"No linter\"",
    "init": "node bin/product-tower.js init",
    "test:syntax": "node scripts/syntax-check.js",
    "test:invariants": "node scripts/invariant-checks.js",
    "harness:health": "powershell -ExecutionPolicy Bypass -File scripts/harness-health.ps1",
    "harness:eval": "powershell -ExecutionPolicy Bypass -File scripts/harness-eval.ps1",
    "harness:hardness": "powershell -ExecutionPolicy Bypass -File scripts/harness-eval.ps1 -IncludeGate -IncludePython",
    "search": "python scripts/web_search.py"
  },
  "files": [
    ".claude/",
    "00_Entry_Point/",
    "01_Framework_Layer/",
    "02_Instance_Layer/",
    "03_Execution_Layer/",
    "04_Learning_Layer/",
    "06_Assets/",
    "07_Archive/",
    "bin/",
    "data/",
    "docs/",
    "plans/",
    "public/",
    "resources/",
    "scripts/",
    "templates/",
    "index.js",
    "package.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "product-management",
    "pmf-validation",
    "claude-code",
    "cursor",
    "vibe-coding",
    "startup",
    "lean-startup",
    "market-research",
    "vietnamese",
    "solo-founder",
    "indie-hacker"
  ],
  "author": "MR.D",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/AIScale-Corp/product-tower-kit.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
